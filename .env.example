# SocrateOS Platform — Environment Configuration
# Copy this file to .env and fill in your values.

# LLM Provider (required)
# Get a key from https://openrouter.ai or use OpenAI/Anthropic directly
OPENROUTER_API_KEY=your_api_key_here

# Default model (optional, defaults to openai/gpt-4o)
DEFAULT_MODEL=openai/gpt-4o

# Database (required)
DATABASE_URL=postgresql://socrateos:password@localhost:5432/socrateos

# Auth (optional — required for OAuth sign-in)
AUTH_SECRET=generate_a_32_byte_random_secret
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
AUTH_URL=http://localhost:3000

# Admin dashboard key (required)
LOGS_SECRET_KEY=your_admin_key_here

# Server (optional)
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT=10/minute
ENVIRONMENT=development
